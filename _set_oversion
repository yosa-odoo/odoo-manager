#!/bin/bash

# Supposed to be called through `source`
#
# Will try to define OVERSION with an Odoo version, in this order:
# - From the option `-o` (for (o)doo version)
#   /!\ If found, the option and its value will be removed from the args
# - Using a regex applied to the first argument
# - From a global variable `GLOBAL_OVERSION`
# - From a script supposed to (s)elect an Odoo (v)ersion
#   By default, its name is `sv`. Can be customized thanks to `SV_SCRIPT_NAME`
#   (All args are passed to the script)
# - From a fallback value
#   By default: `master`. Can be customized thanks to `FALLBACK_OVERSION`
#
# Verbose mode can be enabled thanks to `VERBOSE`

version_rg="(master|(saas-)?[0-9]{2}\.[0-9])"

extract_version() {
  echo "$1" | grep -oE "$version_rg"
}

extract_version_strict() {
  echo "$1" | grep -oE "^$version_rg\$"
}

log() {
  if [[ $VERBOSE -eq 1 ]]; then
    echo "${BASH_SOURCE[0]}: $*"
  fi
}

filtered_args=()

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    -o)
      version_from_option="$2"
      shift 2
      ;;
    *)
      filtered_args+=("$1")
      shift
      ;;
  esac
done

set -- "${filtered_args[@]}"

script_name=${SV_SCRIPT_NAME:-"sv"}
log "Script name: $script_name"

log "First arg: $1"
version_from_arg=$(extract_version "$1")

if [ -n "$version_from_option" ]; then
  log "Version defined thanks to option -o"
  OVERSION=$version_from_option
elif [ -n "$version_from_arg" ]; then
  log "Version defined thanks to args"
  OVERSION=$version_from_arg
elif [ -n "$GLOBAL_OVERSION" ]; then
  log "Version defined thanks to global version"
  OVERSION=$GLOBAL_OVERSION
elif command -v "$script_name" >/dev/null 2>&1; then
  log "Version defined thanks to script $script_name"
  OVERSION=$($script_name "$@")
else
  log "Version defined thanks to fallback"
  version=${FALLBACK_OVERSION:-"master"}
  OVERSION="$version"
fi

log "Result before check: $OVERSION"
OVERSION=$(extract_version_strict "$OVERSION") # final check

log "Final result: $OVERSION"
if [ -z "$OVERSION" ]; then
  echo "No version found!" >&2
  exit 1
fi

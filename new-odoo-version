#!/bin/bash

set -e

repos=("odoo" "enterprise")
ref_version="master"

ODOO_SRC_PATH="${ODOO_SRC_PATH:-$HOME/src}"
ODOO_ENV_PATH="${ODOO_ENV_PATH:-$HOME/odoo-env}"

available=$(ls -1 "$ODOO_ENV_PATH" | grep -E '^(master|(saas-)?[0-9]{2}\.[0-9])$')
versions=${*:-$available}

log() { echo "  [$1] $2"; }

setup_version() {
  local version="$1"

  echo
  echo "Setting up Odoo $version..."

  # --- Git worktrees ---
  echo
  echo "Creating git worktrees..."
  for repo in "${repos[@]}"; do
    log "$repo" "Fetching $version from origin..."
    git -C "$ODOO_SRC_PATH/$ref_version/$repo" fetch -q origin "$version"
    log "$repo" "Adding worktree at $ODOO_SRC_PATH/$version/$repo..."
    git -C "$ODOO_SRC_PATH/$ref_version/$repo" worktree add "$ODOO_SRC_PATH/$version/$repo" "$version"
    log "$repo" "Done"
  done

  # --- Virtualenv ---
  echo
  echo "Creating virtualenv..."
  if command -v uv >/dev/null 2>&1; then
    uv venv --python 3.12 "$ODOO_ENV_PATH/$version"
    echo "  Installing requirements (uv)..."
    uv pip install -q --python "$ODOO_ENV_PATH/$version/bin/python" \
      -r "$ODOO_SRC_PATH/$version/odoo/requirements.txt"
  else
    python3 -m venv "$ODOO_ENV_PATH/$version"
    echo "  Installing requirements..."
    "$ODOO_ENV_PATH/$version/bin/pip" install -q -r "$ODOO_SRC_PATH/$version/odoo/requirements.txt"
  fi
  echo "  Done: $ODOO_ENV_PATH/$version"

  # --- Custom addons symlink ---
  echo
  echo "Setting up custom addons symlink..."
  mkdir -p "$ODOO_SRC_PATH/custom"
  ln -sfn "$ODOO_SRC_PATH/custom" "$ODOO_SRC_PATH/$version/custom"
  echo "  Done: $ODOO_SRC_PATH/$version/custom -> $ODOO_SRC_PATH/custom"

  # --- .odoorc ---
  echo
  echo "Initializing .odoorc..."
  cat > "$ODOO_SRC_PATH/$version/.odoorc" <<EOF
[options]
addons_path = ./odoo/addons,./enterprise,./custom
db_name = $version
db_host = localhost
db_port = 5432
http_port = 8069
limit_time_cpu = 9999
limit_time_real = 9999
server_wide_modules = base,web,server_hook
smtp_port = 1025
smtp_server = 127.0.0.1
without_demo = true
EOF
  echo "  Done: $ODOO_SRC_PATH/$version/.odoorc"

  # --- PyCharm project setup ---
  # config-run is a custom user script that sets up the PyCharm project
  # for the new version. It is not part of this repo — skip if not available.
  # Point Xenv to the new version so config-run picks up the right interpreter.
  echo
  if command -v config-run >/dev/null 2>&1; then
    echo "Updating Xenv symlink..."
    ln -sfn "$ODOO_ENV_PATH/$version" "$ODOO_ENV_PATH/Xenv"
    echo "Running config-run..."
    config-run "$version"
    echo "  Done"
  else
    echo "config-run not found, skipping PyCharm setup."
  fi

  echo
  echo "Odoo $version is ready."
}

for version in $versions; do
  setup_version "$version"
done
